{
  "name": "carelink",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:ci": "jest --ci",
    "test:coverage": "jest --coverage",
    "test:coverage:ci": "jest --ci --coverage --coverageReporters=lcov --coverageReporters=text-summary --coverageReporters=json-summary",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:security": "playwright test e2e/security.spec.ts",
    "test:e2e:perf": "playwright test e2e/performance.spec.ts",
    "test:e2e:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:load": "k6 run load-tests/search-load.js",
    "test:load:soak": "k6 run load-tests/soak-test.js",
    "test:load:booking": "k6 run load-tests/concurrent-booking.js",
    "test:all": "npm run test:ci && npm run test:e2e",
    "prepare": "husky",
    "test:contract": "jest --config=jest.config.contract.js",
    "prelint": "node scripts/ensure-eslint-plugin-link.mjs",
    "pretest": "node scripts/ensure-eslint-plugin-link.mjs",
    "postinstall": "node scripts/ensure-eslint-plugin-link.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@hookform/resolvers": "^5.4.0",
    "@line/liff": "^2.29.0",
    "@next/third-parties": "^16.2.1",
    "@react-map/japan": "^1.0.10",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.2",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/functions": "^3.7.5",
    "@vercel/speed-insights": "^2.0.0",
    "leaflet": "^1.9.4",
    "next": "^15.5.18",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.73.1",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "stripe": "^22.3.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.49.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^10",
    "eslint-config-next": "15.5.15",
    "eslint-plugin-carelink-safety": "file:eslint-plugin-carelink-safety",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "$postcss",
    "qs": "^6.15.2",
    "sharp": "^0.35.0"
  },
  "lint-staged": {
    "*": [
      "gitleaks protect --staged --redact --no-banner"
    ]
  }
}
